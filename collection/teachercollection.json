      "name": "Teachers CRUD",
      "item": [
        {
          "name": "Create",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate random teacherId\r",
                  "let teacherId = Math.floor(Math.random() * 10000);\r",
                  "\r",
                  "// Save in both collection and environment\r",
                  "pm.collectionVariables.set(\"teacherId\", teacherId);\r",
                  "pm.environment.set(\"teacherId\", teacherId);\r",
                  "\r",
                  "// Log for debugging\r",
                  "console.log(\"Generated teacherId:\", teacherId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 or 201\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200,201]);\r",
                  "});\r",
                  "\r",
                  "let res = pm.response.json();\r",
                  "let requestBody = JSON.parse(pm.request.body.raw);\r",
                  "\r",
                  "pm.test(\"Teacher ID exists in response\", function () {\r",
                  "    pm.expect(res.teacherId).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response matches request data\", function () {\r",
                  "    pm.expect(res.name).to.eql(requestBody.name);\r",
                  "    pm.expect(res.email).to.eql(requestBody.email);\r",
                  "    pm.expect(res.teacherId).to.eql(requestBody.teacherId);\r",
                  "    pm.expect(res.department).to.eql(requestBody.department);\r",
                  "    pm.expect(res.designation).to.eql(requestBody.designation);\r",
                  "});\r",
                  "\r",
                  "pm.collectionVariables.set(\"teacherId\", res.teacherId);\r",
                  "pm.environment.set(\"teacherId\", res.teacherId);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
