        {
          "name": "Get All",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "let jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Response body is an array\", function () {\r",
                  "    pm.expect(jsonData).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "\r",
                  "let teacherSchema = {\r",
                  "    \"type\": \"object\",\r",
                  "    \"properties\": {\r",
                  "        \"teacherId\": {\"type\": \"number\"},\r",
                  "        \"name\": {\"type\": \"string\"},\r",
                  "        \"email\": {\"type\": \"string\"},\r",
                  "        \"department\": {\"type\": \"string\"},\r",
                  "        \"designation\": {\"type\": \"string\"}\r",
                  "    },\r",
                  "    \"required\": [\"teacherId\",\"name\",\"email\",\"department\",\"designation\"]\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Teacher schema is valid\", function () {\r",
                  "\r",
                  "    jsonData.forEach(function(item){\r",
                  "\r",
                  "        let valid = tv4.validate(item, teacherSchema);\r",
                  "\r",
                  "        pm.expect(valid).to.be.true;\r",
                  "\r",
                  "    });\r",
                  "\r",
                  "});\r",
                  "\r",
                  "\r",
                  "pm.test(\"Created teacher exists in list\", function () {\r",
                  "\r",
                  "    let teacherId = Number(pm.environment.get(\"teacherId\"));\r",
                  "\r",
                  "    let found = jsonData.some(function(teacher){\r",
                  "        return teacher.teacherId === teacherId;\r",
                  "    });\r",
                  "\r",
                  "    pm.expect(found).to.be.true;\r",
                  "\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
