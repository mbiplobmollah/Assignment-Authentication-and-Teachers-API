                  "const randomIndex = Math.floor(Math.random() * response.length);\r",
                  "const teacher = response[randomIndex];\r",
                  "\r",
                  "pm.environment.set(\"teacherId\", teacher.teacherId);\r",
                  "pm.collectionVariables.set(\"teacherId\", teacher.teacherId);\r",
                  "pm.environment.set(\"teacherName\", teacher.name);\r",
                  "pm.collectionVariables.set(\"teacherName\", teacher.name);\r",
                  "pm.environment.set(\"teacherEmail\", teacher.email);\r",
                  "pm.collectionVariables.set(\"teacherEmail\", teacher.email);\r",
                  "pm.environment.set(\"teacherDepartment\", teacher.department);\r",
                  "pm.collectionVariables.set(\"teacherDepartment\", teacher.department);\r",
                  "pm.environment.set(\"teacherDesignation\", teacher.designation);\r",
                  "pm.collectionVariables.set(\"teacherDesignation\", teacher.designation);"
                ],
