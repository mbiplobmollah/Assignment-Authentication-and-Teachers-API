              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "let jsonData = pm.response.json();\r",
                  "let tokenData = jsonData.authToken;\r",
                  "\r",
                  "pm.test(\"Token exists\", function () {\r",
                  "    pm.expect(jsonData.authToken).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token is not empty\", function () {\r",
                  "    pm.expect(jsonData.authToken).to.not.be.empty;\r",
                  "});\r",
                  "\r",
                  "pm.collectionVariables.set(\"token\", tokenData);\r",
                  "pm.environment.set(\"token\", tokenData);"
